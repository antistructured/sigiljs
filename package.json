{
  "name": "@weipertda/sigiljs",
  "version": "0.2.0",
  "description": "Executable data contracts for JavaScript",
  "keywords": [
    "types",
    "validation",
    "runtime",
    "schema",
    "type-checking",
    "zero-dependency",
    "sigil",
    "bun",
    "javascript",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antistructured/sigiljs.git"
  },
  "license": "MIT",
  "author": {
    "name": "Daniel Weipert",
    "email": "weipertda@gmail.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "main": "./src/index.js",
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "bin": {
    "sigil": "./src/playground.js"
  },
  "scripts": {
    "format": "prettier --write src/",
    "lint": "eslint src/",
    "test": "bun test",
    "bench": "bun run bench/validate-user.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1",
    "node": ">=18"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  }
}
